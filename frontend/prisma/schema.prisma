generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  address       String   @unique                         // wallet address (lowercased)
  username      String?  @unique
  displayName   String?  @map("display_name")
  bio           String?
  avatarUrl     String?  @map("avatar_url")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  articles      Article[]

  @@map("users")
}

model Article {
  id            String   @id @default(uuid()) @db.Uuid
  slug          String   @unique
  title         String
  author        String   @default("Anonymous")
  authorAddress String   @default("0x0000000000000000000000000000000000000000") @map("author_address")
  category      String   @default("General")
  excerpt       String   @default("")
  readTime      String   @default("5 min") @map("read_time")
  content       String
  price         Decimal  @default(0.001) @db.Decimal(10, 4)
  reads         Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")

  // Optional relation — populated when user creates a profile
  userId        String?  @map("user_id") @db.Uuid
  user          User?    @relation(fields: [userId], references: [id])

  @@map("articles")
}
