generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(uuid()) @db.Uuid
  address     String    @unique
  username    String?   @unique
  displayName String?   @map("display_name")
  bio         String?
  avatarUrl   String?   @map("avatar_url")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  articles    Article[]

  @@map("users")
}

model Article {
  id            String    @id @default(uuid()) @db.Uuid
  slug          String    @unique
  title         String
  authorAddress String    @default("0x0000000000000000000000000000000000000000") @map("author_address")
  category      String    @default("General")
  excerpt       String    @default("")
  readTime      String    @default("5 min") @map("read_time")
  content       String
  price         Decimal   @default(0.001) @db.Decimal(10, 4)
  reads         Int       @default(0)
  createdAt     DateTime  @default(now()) @map("created_at")
  userId        String?   @map("user_id") @db.Uuid
  user          User?     @relation(fields: [userId], references: [id])
  comments      Comment[]

  @@map("articles")
}

model Comment {
  id          String   @id @default(uuid()) @db.Uuid
  content     String
  authorAddr  String   @map("author_address")
  articleSlug String   @map("article_slug")
  txHash      String?  @unique @map("tx_hash")
  createdAt   DateTime @default(now()) @map("created_at")
  article     Article  @relation(fields: [articleSlug], references: [slug])

  @@map("comments")
}

model ArticleReadEvent {
  id            String   @id
  txHash        String   @unique @map("tx_hash")
  logIndex      Int      @map("log_index")
  blockNumber   BigInt   @map("block_number")
  reader        String
  writerAddress String   @map("writer_address")
  articleSlug   String   @map("article_slug")
  amount        Decimal  @db.Decimal(20, 18)
  eventType     String   @default("READ") @map("event_type")
  observedAt    DateTime @map("observed_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([observedAt(sort: Desc)])
  @@index([articleSlug, observedAt(sort: Desc)])
  @@map("article_read_events")
}

model AgentQuery {
  id            String   @id @default(uuid()) @db.Uuid
  userAddress   String   @map("user_address")
  prompt        String
  proposal      Json?
  txHash        String?  @map("tx_hash")
  finalAnswer   String?  @map("final_answer")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userAddress])
  @@map("agent_queries")
}
