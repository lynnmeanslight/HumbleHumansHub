generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id            String   @id @default(uuid()) @db.Uuid
  slug          String   @unique
  title         String
  author        String   @default("Anonymous")
  authorAddress String   @default("0x0000000000000000000000000000000000000000") @map("author_address")
  category      String   @default("General")
  excerpt       String   @default("")
  readTime      String   @default("5 min") @map("read_time")
  content       String
  price         Decimal  @default(0.001) @db.Decimal(10, 4)
  reads         Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("articles")
}
